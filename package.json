{
  "name": "web-portal",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx watch api/src/index.ts",
    "env:local": "node scripts/generate-local-env.mjs",
    "build": "tsc -b && tsc -p tsconfig.api.json && vite build",
    "api:build": "tsc -p tsconfig.api.json",
    "api:start": "node build/api/src/index.js",
    "db:migrate": "node build/api/src/migrate.js",
    "preview": "vite preview",
    "test": "vitest --run"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "express": "^5.2.1",
    "framer-motion": "^12.23.12",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.539.0",
    "multer": "^2.0.2",
    "pg": "^8.16.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react-swc": "^4.0.0",
    "autoprefixer": "^10.4.21",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vite": "^7.1.2",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.30.2"
}
